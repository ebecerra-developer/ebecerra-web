.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code — ajustes locales (permisos auto-generados)
.claude/settings.json
.claude/settings.local.json
.playwright-mcp
.mcp.json

# Plantilla de mensajes de commit (workaround heredoc, no debe commitearse)
commit-msg.txt

# Screenshots ad-hoc en raíz (usados durante desarrollo, no se versionan)
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.gif

# Exportaciones de CV / datos personales (vertical corporativo, Europass, etc.)
/EB-*.json
/cv-*.json
/cv-*.pdf

# Junction a workspace externo (no commitear)
_external-plantilla/

# social-kit — track sources only (HTML, CSS, scripts, captions, brand SVGs/PNGs)
# Binarios renderizados (mp4, png output) y node_modules quedan fuera.
# Regenerar: cd social-kit/scripts && node record-animated.mjs

# Carpetas tmp de los renderers
social-kit/**/_tmp-frames/
social-kit/**/_tmp-*/

# Capturas regenerables (derivadas de demos.ebecerra.es)
social-kit/personal/assets/captures/
social-kit/piezas-game/assets/captures/

# Outputs de cada pieza (regenerables desde index.html)
# Cubre la estructura por año/mes: personal/YYYY/MM/<pieza>/...
social-kit/personal/**/final.*
social-kit/personal/**/poster.png
social-kit/personal/**/slide-*.png
social-kit/personal/**/panel-*.png
social-kit/personal/**/panorama-*.png

# Highlights covers y covers de perfil (renderizados desde sus HTML)
social-kit/personal/highlights/*.png
social-kit/personal/covers/*.png

# Carpeta de "para subir": exports manuales regenerables (no es fuente)
social-kit/personal/para-subir/

# Renderizados de drafts archivados (preservamos HTML/MD, no PNG/MP4)
social-kit/personal/2026/04/**/*.png
social-kit/personal/2026/04/**/*.mp4
social-kit/piezas-game/legacy/**/*.png
social-kit/piezas-game/legacy/**/*.mp4
