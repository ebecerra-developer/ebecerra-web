# Sanity
# Secreto del webhook /api/revalidate. Mismo valor en Vercel env + Sanity webhook URL (?secret=...).
SANITY_REVALIDATE_SECRET=your-secret-here
# Token de escritura (solo para mutations server-side).
# SANITY_API_TOKEN=your-write-token-here

# Visual Editing
# Mismo token Viewer que apps/es (el Studio comparte project gdtxcn4l).
SANITY_API_READ_TOKEN=sk_xxx
# Origin absoluto del Studio embebido (vive en apps/es, no aquí). Sin esto el
# overlay click-to-edit no puede devolver al editor al Studio correcto.
NEXT_PUBLIC_SANITY_STUDIO_URL=https://ebecerra.es/studio

# Resend — form /api/contact
# Requiere dominio verificado en Resend (ebecerra.es) + API key.
RESEND_API_KEY=re_xxx
# Destinatario del form /api/contact.
CONTACT_TO_EMAIL=contacto@ebecerra.es
# Remitente. Opcional: si falta usa no-reply@ebecerra.es.
# CONTACT_FROM_EMAIL=no-reply@ebecerra.es

# Chatbot multi-tenant — apps/tech consume el backend SaaS de apps/es como tenant
# El motor Groq vive en apps/es (chats.ebecerra.es). apps/tech solo proxea con su key.
# DB/Sanity/Groq son los mismos en local y prod → default usa prod.
# Solo apuntar a http://localhost:3000 si estás iterando sobre packages/chatbot-saas.
CHATBOT_API_URL=https://chats.ebecerra.es
CHATBOT_TENANT_KEY=tk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin SDK — login + admin/chatbot/* en ebecerra.tech/admin.
# Backend de auth: admin.ebecerra.es. Generar SESSION_SECRET con:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
ADMIN_API_URL=https://admin.ebecerra.es
SESSION_SECRET=
