# Sanity
# Secreto del webhook /api/revalidate. Mismo valor en Vercel env + Sanity webhook URL (?secret=...).
# Reusar el mismo secret que apps/es para no multiplicar credenciales.
SANITY_REVALIDATE_SECRET=your-secret-here

# Chatbot multi-tenant — apps/demos consume el backend SaaS de apps/es como tenant externo
# DB/Sanity/Groq son los mismos en local y prod → default usa prod.
# Solo apuntar a http://localhost:3000 si estás iterando sobre packages/chatbot-saas.
# Cada demoSite tiene su propio tenant (personalidad diferenciada por demo).
# El proxy /api/chatbot mapea demoSlug → CHATBOT_TENANT_KEY_<DEMO_SLUG_UPPER>.
# Cuando añadas un demoSite nuevo: provisionar tenant + añadir env var aquí.
CHATBOT_API_URL=https://chats.ebecerra.es
CHATBOT_TENANT_KEY_EQUILIBRIO=tk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHATBOT_TENANT_KEY_MARTA_SOLANA=tk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHATBOT_TENANT_KEY_CLAUDIA_ENTRENA=tk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHATBOT_TENANT_KEY_ECO=tk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
