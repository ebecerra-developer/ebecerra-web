# Sanity
# Secreto del webhook /api/revalidate. Mismo valor en Vercel env + Sanity webhook URL (?secret=...).
SANITY_REVALIDATE_SECRET=your-secret-here
# Token de escritura (solo para mutations server-side).
# SANITY_API_TOKEN=your-write-token-here

# Visual Editing — Presentation tool en /studio
# Token con rol VIEWER (NO Developer/Editor). Habilita lectura de drafts en
# Draft Mode + subscripción Live Content. Crear en sanity.io/manage → API → Tokens.
SANITY_API_READ_TOKEN=sk_xxx
# Para docTypes de apps/es el origin del iframe es implícito (el dominio donde
# corre el Studio). Solo apps/tech y apps/demos necesitan override porque
# viven en otros orígenes — descomenta si cambian de dominio.
# NEXT_PUBLIC_SANITY_PREVIEW_ORIGIN_TECH=https://ebecerra.tech
# NEXT_PUBLIC_SANITY_PREVIEW_ORIGIN_DEMOS=https://demos.ebecerra.es

# Resend — form de contacto (apps/es/api/contact)
# Si RESEND_API_KEY o CONTACT_TO_EMAIL faltan, /api/contact devuelve 503 y el form muestra error.
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=contacto@ebecerra.es
# Remitente del email. Debe ser una dirección de un dominio verificado en Resend.
# Si se omite, se usa no-reply@ebecerra.es.
# CONTACT_FROM_EMAIL=no-reply@ebecerra.es

# Groq — chatbot (packages/chatbot/server)
# Una sola key compartida entre las 3 apps (rate limits son por cuenta, no por key).
GROQ_API_KEY=gsk_xxx

# Supabase — likes y comentarios del blog + chatbot multi-tenant
# Project URL: dashboard.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (antes "anon"): expuesta al cliente, RLS obligatorio en tablas accedidas desde browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret key (antes "service_role"): bypasea RLS, SOLO server-side (route handlers, server actions). Marcar "Sensitive" en Vercel.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Chatbot multi-tenant — Sanity webhook receiver (chatbot-saas)
# Secret HMAC-SHA256 que verifica firmas de webhooks de Sanity sobre /api/saas/sync-config.
# Mismo valor en Sanity Manage UI → Webhook → "Secret".
# Generar con: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
SANITY_WEBHOOK_SECRET=64-char-hex-string

# Chatbot multi-tenant — apps/es es el backend SaaS (sirve chats.ebecerra.es).
# No necesita CHATBOT_API_URL (se invoca el handler in-process), pero SÍ necesita
# CHATBOT_TENANT_KEY para identificarse como tenant `apps-es` cuando el widget
# de ebecerra.es proxea a /api/chatbot. Sin esta var el chat responde con 503.
CHATBOT_TENANT_KEY=tk_live_xxx

# Social generator — dispara workflows de render en GitHub Actions
# PAT fine-grained con permisos: Actions read/write + Contents read sobre el repo del worker.
# Generar en GitHub → Settings → Developer settings → Personal access tokens → Fine-grained.
GITHUB_DISPATCH_TOKEN=ghp_xxx
# Repo donde vive el workflow social-render.yml (formato owner/repo).
GITHUB_SOCIAL_WORKER_REPO=owner/repo
