# Sanity
# Secreto del webhook /api/revalidate. Mismo valor en Vercel env + Sanity webhook URL (?secret=...).
SANITY_REVALIDATE_SECRET=your-secret-here
# Token de escritura (solo para mutations server-side).
# SANITY_API_TOKEN=your-write-token-here

# Resend — form de contacto (apps/es/api/contact)
# Si RESEND_API_KEY o CONTACT_TO_EMAIL faltan, /api/contact devuelve 503 y el form muestra error.
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=contacto@ebecerra.es
# Remitente del email. Debe ser una dirección de un dominio verificado en Resend.
# Si se omite, se usa no-reply@ebecerra.es.
# CONTACT_FROM_EMAIL=no-reply@ebecerra.es

# Groq — chatbot (packages/chatbot/server)
# Una sola key compartida entre las 3 apps (rate limits son por cuenta, no por key).
GROQ_API_KEY=gsk_xxx

# Supabase — likes y comentarios del blog + logs de chatbot
# Project URL: dashboard.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (antes "anon"): expuesta al cliente, RLS obligatorio en tablas accedidas desde browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret key (antes "service_role"): bypasea RLS, SOLO server-side (route handlers, server actions). Marcar "Sensitive" en Vercel.
SUPABASE_SECRET_KEY=sb_secret_xxx
