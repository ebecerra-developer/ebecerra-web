{
  "name": "ebecerra-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.4.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:es": "npm run dev -w @ebecerra/es",
    "dev:tech": "npm run dev -w @ebecerra/tech",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:marca": "node scripts/lint-marca.mjs",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
